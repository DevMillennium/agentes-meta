{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && npm run build --workspace @phoenix/api",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "memory": 1024,
        "includeFiles": [
          "apps/api/dist/**",
          "node_modules/.prisma/**",
          "node_modules/@prisma/client/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/api/index.ts" }]
}
