{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install && npm run vercel-build:api",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "memory": 1024,
        "includeFiles": "api/phoenix-dist/**"
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/api/index.ts" }]
}
