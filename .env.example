ADMIN_EMAIL="admin@phoenixglobal.com.br"
ADMIN_PASSWORD="troque-por-senha-forte"
JWT_SECRET="troque-por-um-segredo-jwt-forte"
JWT_EXPIRES_IN="12h"
ENABLE_WORKERS="false"
OPENAI_API_KEY=""
