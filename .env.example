USERS_BOOTSTRAP=""

# --- Chatwoot (inbox omnichannel) ---
# Ative para espelhar/atender conversas no Chatwoot. Quando "false" o pipeline atual segue intacto.
CHATWOOT_ENABLED="false"
CHATWOOT_BASE_URL="http://localhost:3001"
CHATWOOT_ACCOUNT_ID=""
CHATWOOT_API_ACCESS_TOKEN=""
CHATWOOT_INBOX_ID_INSTAGRAM=""
CHATWOOT_INBOX_ID_FACEBOOK=""
CHATWOOT_INBOX_ID_WHATSAPP=""
# Segredo (HMAC) opcional para validar webhooks do Chatwoot
CHATWOOT_WEBHOOK_SECRET=""
CHATWOOT_HTTP_TIMEOUT_MS="15000"
