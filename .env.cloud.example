# Variáveis de PRODUÇÃO (nuvem) — copie valores secretos do .env local.
# O .env local permanece para desenvolvimento (localhost).

PHOENIX_TARGET=cloud

# URLs públicas Vercel (primárias)
PHOENIX_CLOUD_API_URL=https://phoenix-marketing-api.vercel.app
# DEPRECADO para operação — use Chatwoot Phoenix (PHOENIX_OMNICHANNEL_URL)
PHOENIX_CLOUD_WEB_URL=https://phoenix-marketing-web-millenniumomnichannel-4893s-projects.vercel.app

# Overrides usados na API em produção (sincronizar com vercel env)
API_PUBLIC_URL=https://phoenix-marketing-api.vercel.app
WEB_APP_URL=https://phoenix-marketing-web-millenniumomnichannel-4893s-projects.vercel.app
API_CORS_ORIGIN=https://phoenix-marketing-web-millenniumomnichannel-4893s-projects.vercel.app
META_REDIRECT_URI=https://phoenix-marketing-api.vercel.app/api/meta/oauth/callback

# Web (projeto phoenix-marketing-web)
NEXT_PUBLIC_API_URL=https://phoenix-marketing-api.vercel.app
NEXT_PUBLIC_META_APP_ID=27447238071580159
NEXT_PUBLIC_META_API_VERSION=v25.0

# App Meta (público)
META_APP_ID=27447238071580159

# Ativos sincronizados após OAuth (2026-05-28) — opcional na Vercel como fallback
META_AD_ACCOUNT_ID=act_35275039595476018
META_PAGE_ID=266953349832334
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841405786843323

# Mesmos segredos do .env local (não commitar valores reais)
# META_APP_SECRET=
# META_CLIENT_TOKEN=
# META_WEBHOOK_VERIFY_TOKEN=
# ADMIN_API_KEY=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# JWT_SECRET=
# OBRIGATÓRIO na Vercel: Postgres na nuvem (Neon, Vercel Postgres, Supabase).
# NÃO use localhost no painel production — o sync local ignora DATABASE_URL localhost.
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/phoenix?sslmode=require
# OPENAI_API_KEY=

# --- Chatwoot (inbox omnichannel) ---
# Chatwoot roda FORA da Vercel (Docker/VPS). A API na Vercel chama a URL pública do Chatwoot.
# CHATWOOT_ENABLED=true
# CHATWOOT_BASE_URL=https://chatwoot.seudominio.com
# CHATWOOT_ACCOUNT_ID=1
# CHATWOOT_API_ACCESS_TOKEN=
# CHATWOOT_INBOX_ID_INSTAGRAM=
# CHATWOOT_INBOX_ID_FACEBOOK=
# CHATWOOT_INBOX_ID_WHATSAPP=
# CHATWOOT_WEBHOOK_SECRET=
