{
  "name": "phoenix-marketing-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace @phoenix/web",
    "dev:api": "npm run dev --workspace @phoenix/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "emulate": "bash scripts/emulate.sh",
    "emulate:ci": "EMULATE_NO_WAIT=1 bash scripts/emulate.sh",
    "meta:bootstrap": "bash scripts/meta-bootstrap.sh",
    "meta:bootstrap:prod": "bash scripts/meta-bootstrap-prod.sh",
    "ops:go-live-check": "bash scripts/ops-go-live-check.sh",
    "ops:open-portals": "bash scripts/open-ops-portals.sh",
    "meta:connect-chrome": "bash scripts/meta-connect-chrome.sh",
    "meta:oauth:auto": "npx tsx scripts/meta-oauth-chrome-auto.ts",
    "meta:fix-oauth-redirect": "bash scripts/meta-fix-oauth-redirect.sh",
    "meta:setup:cloud": "bash scripts/meta-setup-cloud.sh",
    "vercel:sync:cloud": "bash scripts/vercel-sync-cloud-env.sh",
    "meta:push-token:vercel": "bash scripts/meta-push-token-to-vercel.sh",
    "bootstrap": "bash scripts/bootstrap-full.sh",
    "seed:products": "curl -sf -X POST http://localhost:4000/api/products/seed/default -H \"x-api-key: phoenix-local-api-key-16\"",
    "postinstall": "prisma generate",
    "vercel-build:web": "prisma generate && npm run build --workspace @phoenix/web",
    "vercel-build:api": "bash scripts/vercel-prepare-api.sh",
    "predeploy:api": "npm run vercel-build:api",
    "agent:browser": "npx tsx agents/browser-agent/browser-agent.ts",
    "agent:mac": "npx tsx agents/mac-agent/mac-agent.ts",
    "agent:supervisor": "npx tsx agents/supervisor-agent/supervisor-agent.ts",
    "agent:tools": "npx tsx agents/tools-registry/list-tools.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prisma": "^6.9.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "serverless-http": "^4.0.0"
  }
}
